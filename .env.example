# suno-api-lite — variáveis de ambiente (Coolify env vars em produção)
# Não commitar .env real (já no .gitignore raiz).

# ── sunoapi.org (provedor primário, opcional) ─────────────────────────
# Pega chave em https://sunoapi.org/api-key
SUNO_API_KEY=
SUNO_PROVIDER=auto                       # api | cookie | auto (default)
# SUNOAPI_BASE_URL=https://api.sunoapi.org   # raramente precisa mudar

# ── Suno via cookie (fallback / legacy) ────────────────────────────────
SUNO_COOKIE=
SUNO_DRIVER=http                          # http | playwright | playwright_with_fallback
SUNO_MODEL=chirp-crow
USE_WARM_COOKIE=true
WARM_COOKIE_MAX_AGE_MIN=360
SUNO_GATE_MAX=2
SUNO_GATE_TRIES=40
SUNO_GATE_WINDOW_MIN=30
SUNO_OUTAGE_ALERT_ATTEMPT=10

# ── Outros ─────────────────────────────────────────────────────────────
OPENAI_API_KEY=
SUPABASE_URL=https://wedkbwsijfikbkaqnugz.supabase.co/rest/v1
SUPABASE_KEY=
EVO_URL=https://evolutiontechv2.linkarbox.app
EVO_KEY=
